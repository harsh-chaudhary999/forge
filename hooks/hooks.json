{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/session-start.cjs\"",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/prompt-submit.cjs\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob|SemanticSearch|WebFetch|WebSearch|Task|Delete|ReadLints|EditNotebook|TodoWrite|Shell|GenerateImage|AskQuestion|SwitchMode|AwaitShell|call_mcp_tool|fetch_mcp_resource",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/pre-tool-use.cjs\"",
            "async": false
          }
        ]
      }
    ]
  }
}
